{
  "compilerOptions": {
    "module": "ESNext",
    "moduleDetection": "auto",
    "verbatimModuleSyntax": false,
    "target": "esnext",
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true,
  }
}
